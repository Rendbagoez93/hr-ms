{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Company Profile Schema",
  "description": "Schema for company profile configuration in HR Management System",
  "type": "object",
  "required": ["company"],
  "properties": {
    "company": {
      "type": "object",
      "required": ["name", "contact", "address", "hr_settings"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Company display name",
          "minLength": 1
        },
        "legal_name": {
          "type": "string",
          "description": "Legal/registered company name"
        },
        "description": {
          "type": "string",
          "description": "Brief company description"
        },
        "industry": {
          "type": "string",
          "description": "Industry sector"
        },
        "founded": {
          "type": "integer",
          "description": "Year company was founded",
          "minimum": 1800,
          "maximum": 2100
        },
        "tax_id": {
          "type": "string",
          "description": "Tax identification number"
        },
        "registration_number": {
          "type": "string",
          "description": "Official company registration number"
        },
        "contact": {
          "type": "object",
          "required": ["email", "phone"],
          "properties": {
            "email": {
              "type": "string",
              "format": "email",
              "description": "Primary contact email"
            },
            "phone": {
              "type": "string",
              "description": "Primary contact phone number"
            },
            "website": {
              "type": "string",
              "format": "uri",
              "description": "Company website URL"
            },
            "social_media": {
              "type": "object",
              "description": "Company social media profile URLs",
              "properties": {
                "linkedin": {
                  "type": "string",
                  "format": "uri",
                  "description": "LinkedIn company page URL"
                },
                "instagram": {
                  "type": "string",
                  "format": "uri",
                  "description": "Instagram profile URL"
                },
                "twitter": {
                  "type": "string",
                  "format": "uri",
                  "description": "Twitter/X profile URL"
                }
              },
              "additionalProperties": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "address": {
          "type": "object",
          "required": ["street", "city", "country"],
          "properties": {
            "street": {
              "type": "string",
              "description": "Street address"
            },
            "city": {
              "type": "string",
              "description": "City name"
            },
            "state": {
              "type": "string",
              "description": "State or province"
            },
            "postal_code": {
              "type": "string",
              "description": "Postal or ZIP code"
            },
            "country": {
              "type": "string",
              "description": "Country name"
            }
          }
        },
        "hr_settings": {
          "type": "object",
          "required": ["working_hours_per_week", "default_currency", "payroll_cycle"],
          "properties": {
            "working_hours_per_week": {
              "type": "number",
              "description": "Standard working hours per week",
              "minimum": 0,
              "maximum": 168
            },
            "probation_period_days": {
              "type": "integer",
              "description": "Default probation period in days",
              "minimum": 0
            },
            "annual_leave_days": {
              "type": "integer",
              "description": "Default annual leave days",
              "minimum": 0
            },
            "sick_leave_days": {
              "type": "integer",
              "description": "Default sick leave days",
              "minimum": 0
            },
            "default_currency": {
              "type": "string",
              "description": "Default currency code (ISO 4217)",
              "pattern": "^[A-Z]{3}$"
            },
            "payroll_cycle": {
              "type": "string",
              "description": "Payroll payment frequency",
              "enum": ["weekly", "biweekly", "monthly", "quarterly"]
            },
            "employee_id_format": {
              "type": "string",
              "description": "Format template for generating employee IDs"
            }
          }
        },
        "leave_policies": {
          "type": "array",
          "description": "List of company leave policy definitions",
          "items": {
            "type": "object",
            "required": ["type", "label", "days", "carry_over", "max_carry_over_days"],
            "properties": {
              "type": {
                "type": "string",
                "description": "Leave type identifier"
              },
              "label": {
                "type": "string",
                "description": "Human-readable leave type label"
              },
              "days": {
                "type": "integer",
                "description": "Number of leave days allocated",
                "minimum": 0
              },
              "carry_over": {
                "type": "boolean",
                "description": "Whether unused days can be carried over to the next year"
              },
              "max_carry_over_days": {
                "type": "integer",
                "description": "Maximum number of days that can be carried over",
                "minimum": 0
              }
            }
          }
        },
        "job_levels": {
          "type": "array",
          "description": "Ordered list of job seniority levels",
          "items": {
            "type": "object",
            "required": ["level", "code", "label"],
            "properties": {
              "level": {
                "type": "integer",
                "description": "Numeric seniority level (higher = more senior)",
                "minimum": 1
              },
              "code": {
                "type": "string",
                "description": "Short code for the level"
              },
              "label": {
                "type": "string",
                "description": "Display label for the level"
              }
            }
          }
        },
        "benefits": {
          "type": "object",
          "description": "Employee benefit flags",
          "properties": {
            "health_insurance": {
              "type": "boolean",
              "description": "Health insurance provided"
            },
            "dental_insurance": {
              "type": "boolean",
              "description": "Dental insurance provided"
            },
            "vision_insurance": {
              "type": "boolean",
              "description": "Vision insurance provided"
            },
            "life_insurance": {
              "type": "boolean",
              "description": "Life insurance provided"
            },
            "meal_allowance": {
              "type": "boolean",
              "description": "Meal allowance provided"
            },
            "transportation_allowance": {
              "type": "boolean",
              "description": "Transportation allowance provided"
            },
            "remote_work_allowance": {
              "type": "boolean",
              "description": "Remote work allowance provided"
            },
            "annual_bonus": {
              "type": "boolean",
              "description": "Annual bonus provided"
            },
            "performance_bonus": {
              "type": "boolean",
              "description": "Performance-based bonus provided"
            }
          },
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "business_hours": {
          "type": "object",
          "properties": {
            "timezone": {
              "type": "string",
              "description": "IANA timezone identifier"
            },
            "weekdays": {
              "type": "object",
              "properties": {
                "monday": { "$ref": "#/definitions/workday" },
                "tuesday": { "$ref": "#/definitions/workday" },
                "wednesday": { "$ref": "#/definitions/workday" },
                "thursday": { "$ref": "#/definitions/workday" },
                "friday": { "$ref": "#/definitions/workday" }
              }
            },
            "weekend": {
              "type": "object",
              "properties": {
                "saturday": {
                  "oneOf": [
                    { "$ref": "#/definitions/workday" },
                    { "type": "null" }
                  ]
                },
                "sunday": {
                  "oneOf": [
                    { "$ref": "#/definitions/workday" },
                    { "type": "null" }
                  ]
                }
              }
            }
          }
        },
        "departments": {
          "type": "array",
          "description": "List of company departments",
          "items": {
            "type": "object",
            "required": ["name", "code"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Department name"
              },
              "code": {
                "type": "string",
                "description": "Department code/abbreviation"
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "workday": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "string",
          "description": "Start time in HH:MM format",
          "pattern": "^([0-1][0-9]|2[0-3]):[0-5][0-9]$"
        },
        "end": {
          "type": "string",
          "description": "End time in HH:MM format",
          "pattern": "^([0-1][0-9]|2[0-3]):[0-5][0-9]$"
        }
      }
    }
  }
}
