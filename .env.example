# Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# DJANGO SETTINGS
# =============================================================================

# Environment: development or production
ENVIRONMENT=development

# Django Secret Key (MUST be changed in production!)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-change-me-in-production

# Debug Mode (set to False in production)
DEBUG=True

# Allowed Hosts (comma-separated list)
# Example: ALLOWED_HOSTS=example.com,www.example.com,api.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Allowed Origins (comma-separated list)
# Example: CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=

# =============================================================================
# INTERNATIONALIZATION
# =============================================================================

LANGUAGE_CODE=en-us
TIME_ZONE=Asia/Jakarta
USE_I18N=True
USE_TZ=True

# =============================================================================
# SQLITE DATABASE (Development)
# =============================================================================

SQLITE_DB_NAME=db.sqlite3

# =============================================================================
# POSTGRESQL DATABASE (Production)
# =============================================================================

# PostgreSQL Host
POSTGRES_HOST=localhost

# PostgreSQL Port
POSTGRES_PORT=5432

# PostgreSQL User
POSTGRES_USER=your_db_user

# PostgreSQL Password
POSTGRES_PASSWORD=your_db_password

# PostgreSQL Database Name
POSTGRES_DB=hr_ms_db

# PostgreSQL Schema
POSTGRES_SCHEMA=public

# Connection Settings
POSTGRES_CONN_MAX_AGE=600
POSTGRES_POOL_SIZE=20
POSTGRES_SSL_MODE=require
