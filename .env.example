# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Django core
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — generate a unique key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# True for local development, False for staging/production
DEBUG=False

# One of: local | development | staging | production
ENVIRONMENT=production

# JSON-style list, e.g. ["example.com","www.example.com"]
ALLOWED_HOSTS=["example.com"]

# BCP-47 language code, e.g. en-us, id, fr
LANGUAGE_CODE=en-us

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────

# JSON-style list of allowed origins, e.g. ["https://app.example.com"]
CORS_ALLOWED_ORIGINS=[]

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# SQLITE  — uses a local db.sqlite3 file (no further vars required)
# POSTGRES — fill in all DATABASE_* vars below
DATABASE_ENGINE=SQLITE

# ── PostgreSQL (required when DATABASE_ENGINE=POSTGRES) ──────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your-db-password
DATABASE_NAME=hr_ms
